{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Synth",
  "scopeName": "source.synth",
  "fileTypes": ["syn"],

  "patterns": [
    { "include": "#block-comment" },
    { "include": "#line-comment" },
    { "include": "#triple-string" },
    { "include": "#template-literal" },
    { "include": "#annotation-effects" },
    { "include": "#annotation-intent" },
    { "include": "#annotation-flag" },
    { "include": "#fn-declaration" },
    { "include": "#record-declaration" },
    { "include": "#type-declaration" },
    { "include": "#interface-declaration" },
    { "include": "#enum-declaration" },
    { "include": "#control-keywords" },
    { "include": "#declaration-keywords" },
    { "include": "#async-keywords" },
    { "include": "#logical-keywords" },
    { "include": "#builtin-types" },
    { "include": "#type-reference" },
    { "include": "#constants" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#pipeline-operator" },
    { "include": "#nullish-operators" },
    { "include": "#match-arm-separator" },
    { "include": "#arrow-lambda" },
    { "include": "#arrow-return" },
    { "include": "#type-annotation-sep" },
    { "include": "#spread" },
    { "include": "#field-shorthand" },
    { "include": "#hash-pattern" },
    { "include": "#comparison-operators" },
    { "include": "#wildcard" }
  ],

  "repository": {

    "block-comment": {
      "name": "comment.block.synth",
      "begin": "/\\*",
      "end": "\\*/",
      "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.synth" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.comment.end.synth" } }
    },

    "line-comment": {
      "name": "comment.line.double-slash.synth",
      "match": "//.*$"
    },

    "triple-string": {
      "name": "string.quoted.triple.synth",
      "begin": "\"\"\"",
      "end": "\"\"\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.synth" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.synth" } },
      "patterns": [
        { "name": "constant.character.escape.synth", "match": "\\\\." }
      ]
    },

    "template-literal": {
      "name": "string.template.synth",
      "begin": "`",
      "end": "`",
      "beginCaptures": { "0": { "name": "punctuation.definition.template.begin.synth" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.template.end.synth" } },
      "patterns": [
        {
          "name": "meta.template.expression.synth",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.synth" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.template-expression.end.synth" } },
          "patterns": [
            { "include": "#template-expression-inner" }
          ]
        },
        { "name": "constant.character.escape.synth", "match": "\\\\." }
      ]
    },

    "template-expression-inner": {
      "patterns": [
        { "include": "#line-comment" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#constants" },
        { "include": "#builtin-types" },
        { "include": "#control-keywords" },
        { "include": "#declaration-keywords" },
        { "include": "#comparison-operators" }
      ]
    },

    "annotation-effects": {
      "match": "(@effects)\\s*(\\[[^\\]]*\\])?",
      "captures": {
        "1": { "name": "storage.modifier.annotation.synth" },
        "2": { "name": "support.other.effects-list.synth" }
      }
    },

    "annotation-intent": {
      "begin": "(@intent)\\s*(\")",
      "end": "\"",
      "beginCaptures": {
        "1": { "name": "storage.modifier.annotation.synth" },
        "2": { "name": "punctuation.definition.string.begin.synth" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.synth" }
      },
      "contentName": "string.quoted.double.annotation-value.synth"
    },

    "annotation-flag": {
      "name": "storage.modifier.annotation.synth",
      "match": "@(pure|total|memo|exhaustive|test|throws)\\b"
    },

    "fn-declaration": {
      "match": "\\b(async\\s+)?(fn)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "captures": {
        "1": { "name": "keyword.control.async.synth" },
        "2": { "name": "keyword.declaration.function.synth" },
        "3": { "name": "entity.name.function.synth" }
      }
    },

    "record-declaration": {
      "match": "\\b(record)\\s+([A-Z][a-zA-Z0-9_$]*)",
      "captures": {
        "1": { "name": "keyword.declaration.type.synth" },
        "2": { "name": "entity.name.type.synth" }
      }
    },

    "type-declaration": {
      "match": "\\b(type)\\s+([A-Z][a-zA-Z0-9_$]*)",
      "captures": {
        "1": { "name": "keyword.declaration.type.synth" },
        "2": { "name": "entity.name.type.synth" }
      }
    },

    "interface-declaration": {
      "match": "\\b(interface)\\s+([A-Z][a-zA-Z0-9_$]*)",
      "captures": {
        "1": { "name": "keyword.declaration.type.synth" },
        "2": { "name": "entity.name.type.synth" }
      }
    },

    "enum-declaration": {
      "match": "\\b(enum)\\s+([A-Z][a-zA-Z0-9_$]*)",
      "captures": {
        "1": { "name": "keyword.declaration.type.synth" },
        "2": { "name": "entity.name.type.synth" }
      }
    },

    "control-keywords": {
      "name": "keyword.control.synth",
      "match": "\\b(if|else|match|return|while|for|in|break|continue|when)\\b"
    },

    "declaration-keywords": {
      "name": "keyword.other.synth",
      "match": "\\b(let|new|where|mut|refine|infer|store|on|import|export|from|as|module|do|typeof|instanceof)\\b"
    },

    "async-keywords": {
      "name": "keyword.control.async.synth",
      "match": "\\b(async|await)\\b"
    },

    "logical-keywords": {
      "name": "keyword.operator.word.synth",
      "match": "\\b(and|or|not)\\b"
    },

    "builtin-types": {
      "name": "support.type.primitive.synth",
      "match": "\\b(int|float|string|bool|void|any|list)\\b"
    },

    "type-reference": {
      "name": "support.type.synth",
      "match": "\\b([A-Z][a-zA-Z0-9_$]*)\\b"
    },

    "constants": {
      "name": "constant.language.synth",
      "match": "\\b(true|false|null|undefined)\\b"
    },

    "string": {
      "name": "string.quoted.double.synth",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.synth" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.synth" } },
      "patterns": [
        {
          "name": "meta.interpolation.synth",
          "match": "\\{[a-zA-Z_$][a-zA-Z0-9_$]*(?:\\.[a-zA-Z_$][a-zA-Z0-9_$]*)*\\}",
          "captures": {
            "0": { "name": "variable.other.interpolated.synth" }
          }
        },
        { "name": "constant.character.escape.synth", "match": "\\\\." }
      ]
    },

    "number": {
      "patterns": [
        {
          "name": "constant.numeric.hex.synth",
          "match": "\\b0x[0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.binary.synth",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.float.synth",
          "match": "\\b[0-9]+(?:_[0-9]+)*\\.[0-9]+(?:_[0-9]+)*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.synth",
          "match": "\\b[0-9]+(?:_[0-9]+)*\\b"
        }
      ]
    },

    "pipeline-operator": {
      "name": "keyword.operator.pipeline.synth",
      "match": "\\|>"
    },

    "nullish-operators": {
      "patterns": [
        { "name": "keyword.operator.nullish.synth", "match": "\\?\\?" },
        { "name": "keyword.operator.optional.synth", "match": "\\?\\." }
      ]
    },

    "match-arm-separator": {
      "name": "punctuation.separator.match-arm.synth",
      "match": "(?<=[\\s{(,])\\|(?!>)|^\\s*\\|(?!>)"
    },

    "arrow-lambda": {
      "name": "keyword.operator.arrow.synth",
      "match": "=>"
    },

    "arrow-return": {
      "name": "keyword.operator.return-type.synth",
      "match": "->"
    },

    "type-annotation-sep": {
      "name": "keyword.operator.type-annotation.synth",
      "match": "::"
    },

    "spread": {
      "name": "keyword.operator.spread.synth",
      "match": "\\.\\.\\."
    },

    "field-shorthand": {
      "name": "variable.other.field-shorthand.synth",
      "match": "(?<=[(,\\s])\\.[a-zA-Z_$][a-zA-Z0-9_$]*(?=[,)\\s])"
    },

    "hash-pattern": {
      "name": "constant.other.pattern-ref.synth",
      "match": "#[a-zA-Z_][a-zA-Z0-9_]*"
    },

    "comparison-operators": {
      "patterns": [
        { "name": "keyword.operator.comparison.synth", "match": "===|!==|>=|<=|>(?!>)|<(?!<)" },
        { "name": "keyword.operator.logical.synth", "match": "&&|\\|\\|" },
        { "name": "keyword.operator.assignment.synth", "match": "(?<!=)=(?![=>])" }
      ]
    },

    "wildcard": {
      "name": "variable.language.wildcard.synth",
      "match": "(?<=[\\s|])_(?=[\\s=>]|$)"
    }
  }
}
