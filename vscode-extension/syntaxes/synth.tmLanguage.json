{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Synth",
  "scopeName": "source.synth",
  "fileTypes": ["axn"],

  "patterns": [
    { "include": "#block-comment" },
    { "include": "#line-comment" },
    { "include": "#annotation-effects" },
    { "include": "#annotation-intent" },
    { "include": "#annotation-flag" },
    { "include": "#fn-declaration" },
    { "include": "#record-declaration" },
    { "include": "#type-declaration" },
    { "include": "#control-keywords" },
    { "include": "#declaration-keywords" },
    { "include": "#builtin-types" },
    { "include": "#type-reference" },
    { "include": "#constants" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#pipeline-operator" },
    { "include": "#match-arm-separator" },
    { "include": "#arrow-lambda" },
    { "include": "#arrow-return" },
    { "include": "#type-annotation-sep" },
    { "include": "#spread" },
    { "include": "#field-shorthand" },
    { "include": "#hash-pattern" },
    { "include": "#comparison-operators" },
    { "include": "#wildcard" }
  ],

  "repository": {

    "block-comment": {
      "name": "comment.block.synth",
      "begin": "/\\*",
      "end": "\\*/",
      "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.synth" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.comment.end.synth" } },
      "patterns": [
        { "name": "comment.block.synth", "match": "." }
      ]
    },

    "line-comment": {
      "name": "comment.line.double-slash.synth",
      "match": "//.*$",
      "captures": {
        "0": { "name": "comment.line.double-slash.synth" }
      }
    },

    "annotation-effects": {
      "comment": "@effects [dom.write, state.mutable, rng, ...] — effects list gets its own color",
      "match": "(@effects)\\s*(\\[[^\\]]*\\])?",
      "captures": {
        "1": { "name": "storage.modifier.annotation.synth" },
        "2": { "name": "support.other.effects-list.synth" }
      }
    },

    "annotation-intent": {
      "comment": "@intent \"...\" — string value is part of the annotation, highlight together",
      "begin": "(@intent)\\s*(\")",
      "end": "\"",
      "beginCaptures": {
        "1": { "name": "storage.modifier.annotation.synth" },
        "2": { "name": "punctuation.definition.string.begin.synth" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.synth" }
      },
      "contentName": "string.quoted.double.annotation-value.synth"
    },

    "annotation-flag": {
      "comment": "Stand-alone boolean annotations: @pure @total @memo @exhaustive",
      "name": "storage.modifier.annotation.synth",
      "match": "@(pure|total|memo|exhaustive)\\b"
    },

    "fn-declaration": {
      "comment": "fn functionName — highlights keyword and function name separately",
      "match": "\\b(fn)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
      "captures": {
        "1": { "name": "keyword.declaration.function.synth" },
        "2": { "name": "entity.name.function.synth" }
      }
    },

    "record-declaration": {
      "comment": "record RecordName",
      "match": "\\b(record)\\s+([A-Z][a-zA-Z0-9_$]*)",
      "captures": {
        "1": { "name": "keyword.declaration.type.synth" },
        "2": { "name": "entity.name.type.synth" }
      }
    },

    "type-declaration": {
      "comment": "type TypeName = ...",
      "match": "\\b(type)\\s+([A-Z][a-zA-Z0-9_$]*)",
      "captures": {
        "1": { "name": "keyword.declaration.type.synth" },
        "2": { "name": "entity.name.type.synth" }
      }
    },

    "control-keywords": {
      "comment": "if else match return — control flow",
      "name": "keyword.control.synth",
      "match": "\\b(if|else|match|return)\\b"
    },

    "declaration-keywords": {
      "comment": "let new where — declaration and constraint keywords",
      "name": "keyword.other.synth",
      "match": "\\b(let|new|where)\\b"
    },

    "builtin-types": {
      "comment": "int float string bool void any — primitive type names",
      "name": "support.type.primitive.synth",
      "match": "\\b(int|float|string|bool|void|any)\\b"
    },

    "type-reference": {
      "comment": "Capitalized identifiers used as type names: Hero, HP, StatValue, etc.",
      "name": "support.type.synth",
      "match": "\\b([A-Z][a-zA-Z0-9_$]*)\\b"
    },

    "constants": {
      "name": "constant.language.synth",
      "match": "\\b(true|false|null|undefined)\\b"
    },

    "string": {
      "comment": "Double-quoted strings with {ident} and {ident.prop} interpolation",
      "name": "string.quoted.double.synth",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.synth" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.string.end.synth" } },
      "patterns": [
        {
          "comment": "String interpolation: {ident} or {ident.prop.nested}",
          "name": "meta.interpolation.synth",
          "match": "\\{[a-zA-Z_$][a-zA-Z0-9_$]*(?:\\.[a-zA-Z_$][a-zA-Z0-9_$]*)*\\}",
          "captures": {
            "0": { "name": "variable.other.interpolated.synth" }
          }
        },
        {
          "comment": "Escape sequences",
          "name": "constant.character.escape.synth",
          "match": "\\\\."
        }
      ]
    },

    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.synth",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.synth",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "pipeline-operator": {
      "comment": "|> — the core composition operator, gets its own distinct scope",
      "name": "keyword.operator.pipeline.synth",
      "match": "\\|>"
    },

    "match-arm-separator": {
      "comment": "| at the start of a match arm (not |>)",
      "name": "punctuation.separator.match-arm.synth",
      "match": "(?<=[\\s{(,])\\|(?!>)|^\\s*\\|(?!>)"
    },

    "arrow-lambda": {
      "comment": "=> in lambda expressions and match arms",
      "name": "keyword.operator.arrow.synth",
      "match": "=>"
    },

    "arrow-return": {
      "comment": "-> in function return type annotations: fn foo :: () -> int",
      "name": "keyword.operator.return-type.synth",
      "match": "->"
    },

    "type-annotation-sep": {
      "comment": ":: separates a function name from its full type signature",
      "name": "keyword.operator.type-annotation.synth",
      "match": "::"
    },

    "spread": {
      "comment": "... spread operator in object/array literals",
      "name": "keyword.operator.spread.synth",
      "match": "\\.\\.\\."
    },

    "field-shorthand": {
      "comment": ".fieldName accessor shorthand in pipelines: filter(.alive), map(.name)",
      "name": "variable.other.field-shorthand.synth",
      "match": "(?<=[(,\\s])\\.[a-zA-Z_$][a-zA-Z0-9_$]*(?=[,)\\s])"
    },

    "hash-pattern": {
      "comment": "#email #url — semantic regex pattern references in where clauses",
      "name": "constant.other.pattern-ref.synth",
      "match": "#[a-zA-Z_][a-zA-Z0-9_]*"
    },

    "comparison-operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.synth",
          "match": "===|!==|>=|<=|>(?!>)|<(?!<)"
        },
        {
          "name": "keyword.operator.logical.synth",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.assignment.synth",
          "match": "(?<!=)=(?![=>])"
        }
      ]
    },

    "wildcard": {
      "comment": "_ wildcard in match patterns",
      "name": "variable.language.wildcard.synth",
      "match": "(?<=[\\s|])_(?=[\\s=>]|$)"
    }
  }
}
