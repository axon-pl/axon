{
  "name": "synth-language",
  "displayName": "Synth Language",
  "description": "Syntax highlighting, bracket matching, and language support for the Synth programming language (.syn files)",
  "version": "1.0.9",
  "publisher": "synth-lang",
  "license": "MIT",
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:synth",
    "onStartupFinished",
    "workspaceContains:**/*.syn"
  ],
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "synth",
    "syn",
    "syntax",
    "highlighting",
    "language",
    "transpiler",
    "ai-native"
  ],
  "homepage": "https://synth-pl.github.io/synth/",
  "bugs": {
    "url": "https://github.com/synth-pl/synth/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/synth-pl/synth.git",
    "directory": "vscode-extension"
  },
  "galleryBanner": {
    "color": "#0d0221",
    "theme": "dark"
  },
  "contributes": {
    "commands": [
      {
        "command": "synth.rebindLanguage",
        "title": "Synth: Reapply Language Mode"
      }
    ],
    "languages": [
      {
        "id": "synth",
        "aliases": ["Synth", "synth"],
        "extensions": [".syn"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "synth",
        "scopeName": "source.synth",
        "path": "./syntaxes/synth.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[synth]": {
        "editor.semanticHighlighting.enabled": false
      },
      "files.associations": {
        "*.syn": "synth"
      }
    }
  }
}
