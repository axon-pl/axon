{
  "name": "synth-language",
  "displayName": "Synth Language",
  "description": "Syntax highlighting, bracket matching, and language support for the Synth programming language (.syn files)",
  "version": "0.1.0",
  "publisher": "synth-lang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/synth-lang/synth"
  },
  "contributes": {
    "languages": [
      {
        "id": "synth",
        "aliases": ["Synth", "synth"],
        "extensions": [".syn"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "synth",
        "scopeName": "source.synth",
        "path": "./syntaxes/synth.tmLanguage.json"
      }
    ]
  }
}
